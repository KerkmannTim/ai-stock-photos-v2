# Stock Photo Shop v2 — Backend Environment

# Port to run the Express server on
PORT=3001

# Path to SQLite database file (relative or absolute)
DB_PATH=./database.sqlite

# Directory for uploaded images
UPLOAD_DIR=./uploads

# ── Stripe (TEST MODE) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── JWT (Auth) ──
JWT_SECRET=change-me-in-production-2026
JWT_EXPIRES_IN=7d

# ── SMTP / E-Mail ──
# Falls SMTP-Daten fehlen, läuft das Backend im TEST-MODUS
# (E-Mails werden geloggt, aber NICHT versendet).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@stock-photo-shop.de

# Öffentliche URL des Shops (für Download-Links in E-Mails)
APP_URL=http://localhost:3001
